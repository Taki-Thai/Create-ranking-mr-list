# Copy to .env for local runs (never commit the real .env).
# In GitHub Actions these are injected from repository Secrets - see
# .github/workflows/data_creation.yml

# Full JSON content of the GCP service account key, as a single line.
GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","...":"..."}

# GCP project that hosts the BigQuery dataset.
PROJECT_ID=your-gcp-project-id

# BigQuery dataset that holds mr_master / hospital_master / lp_label_master.
DATASET_ID=your-bigquery-dataset-id
